#!/bin/bash

alias ls='ls -lF --color=auto'
alias l='ls -l'
alias la='ls -la'
alias agent='eval "$(ssh-agent -s)"'
alias git-key='agent;ssh-add ~/.ssh/id_github'
alias grep='grep --color=auto'
alias fgrep='fgrep --color=auto'
alias egrep='egrep --color=auto'
alias g='git'
alias v='vim'
# Enables alias expansion while using sudo
alias sudo='sudo '
alias unbuffered='stdbuf -i0 -o0 -e0'
alias local-https='caddy reverse-proxy --from localhost --to localhost:8080'

alias ona='gitpod'
#alias ona-id='gitpod env list --field id --limit 1 --running-only 2>/dev/null'
alias ona-id="gitpod env list --running-only 2>/dev/null | tail -n +2 | cut -d ' ' -f 1,2 |  sed -E 's/([^[:space:]]+)[[:space:]]+(.*)/\2 \1/' | sort --human-numeric-sort | fzf --reverse --height=90% --prompt='Ona instance > ' | cut -d ' ' -f 2"
alias ona-open='gitpod env open $(ona-id)'
alias ona-ssh='ssh -t $(ona-id).gitpod.environment "zsh -l"'
alias ona-mount='/Users/jjohnson/dev/dotfiles-vanta/ona-mount'

alias sessions='~/configure/claude-sessions'

if command -v ack-grep >/dev/null; then
  alias ack='ack-grep'
fi
